<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rplbo.app.manajemen_perpustakaan.AdminDashboardController">
    <left>
        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #2b7a63; -fx-padding: 20;">
            <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;" text="ADMIN PANEL">
                <VBox.margin><Insets bottom="20.0" /></VBox.margin>
            </Label>
            <Button fx:id="btnMenuDashboard" onAction="#showDashboard" maxWidth="Infinity" style="-fx-background-color: #1e5646; -fx-text-fill: white; -fx-alignment: center-left;" text="Dashboard" />
            <Button fx:id="btnMenuDataBuku" onAction="#showDataBuku" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Data Buku" />
            <Button fx:id="btnMenuAnggota" onAction="#showDataAnggota" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Data Anggota" />
            <Button fx:id="btnMenuPinjaman" onAction="#showPinjaman" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Peminjaman" />
            <VBox VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #ff4444; -fx-text-fill: white;" text="LOGOUT" />
        </VBox>
    </left>
    <center>
        <StackPane>
            <VBox fx:id="pageDashboard" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 30;" visible="true">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Dashboard Informasi" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Buka Form Peminjaman Offline" onAction="#bukaFormPeminjaman" style="-fx-background-color: #009688; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
                </HBox>
                <HBox spacing="20.0">
                    <VBox alignment="CENTER" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                        <Label text="Total Buku" textFill="#777777" />
                        <Label fx:id="totalBukuLabel" style="-fx-font-size: 24; -fx-font-weight: bold;" text="0" />
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                        <Label text="Anggota Aktif" textFill="#777777" />
                        <Label fx:id="totalAnggotaLabel" style="-fx-font-size: 24; -fx-font-weight: bold;" text="0" />
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                        <Label text="Buku Dipinjam" textFill="#777777" />
                        <Label fx:id="totalPinjamLabel" style="-fx-font-size: 24; -fx-font-weight: bold;" text="0" />
                    </VBox>
                </HBox>
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                        <Label text="Statistik Status Buku" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                        <PieChart fx:id="chartBuku" VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <VBox prefWidth="350" style="-fx-background-color: #ffcccc; -fx-background-radius: 10; -fx-padding: 20;" spacing="10">
                        <Label text="⚠️ Laporan &amp; Keluhan User" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #cc0000;"/>
                        <ListView fx:id="listKeluhan" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="pageDataBuku" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 30;" visible="false">
                <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Kelola Data Buku" />
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="350" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                        <TextField fx:id="titleField" promptText="Judul Buku" />
                        <TextField fx:id="authorField" promptText="Pengarang" />
                        <TextField fx:id="publisherField" promptText="Penerbit" />
                        <HBox spacing="10">
                            <TextField fx:id="yearField" promptText="Tahun Terbit" prefWidth="150" />
                            <TextField fx:id="pagesField" promptText="Jml Halaman" prefWidth="150" />
                        </HBox>
                        <ComboBox fx:id="genreComboBox" promptText="Pilih Genre" maxWidth="Infinity" />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Pilih Cover" onAction="#handleSelectImage" />
                            <Label fx:id="imagePathLabel" text="Tidak ada" style="-fx-font-size: 10;" />
                        </HBox>
                        <ImageView fx:id="previewImage" fitHeight="100" fitWidth="80" preserveRatio="true" />
                        <Button text="SIMPAN BUKU" maxWidth="Infinity" style="-fx-background-color: #2b7a63; -fx-text-fill: white;" onAction="#handleAddBook" />
                    </VBox>
                    <TableView fx:id="bookTable" HBox.hgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colJudul" text="Judul" prefWidth="200" />
                            <TableColumn fx:id="colPengarang" text="Pengarang" prefWidth="150" />
                            <TableColumn fx:id="colPenerbit" text="Penerbit" prefWidth="120" />
                            <TableColumn fx:id="colGenre" text="Genre" prefWidth="100" />
                        </columns>
                    </TableView>
                </HBox>
            </VBox>

            <VBox fx:id="pageDataAnggota" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 30;" visible="false">
                <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Daftar Anggota (User)" />
                <TableView fx:id="tableAnggota" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colAnggotaId" text="ID User" prefWidth="100" />
                        <TableColumn fx:id="colAnggotaUsername" text="Username" prefWidth="300" />
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="pagePinjaman" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-padding: 30;" visible="false">
                <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Data Peminjaman Buku" />
                <TableView fx:id="tablePinjamanAdmin" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPinjamId" text="ID Pinjam" prefWidth="80" />
                        <TableColumn fx:id="colPinjamUser" text="Username" prefWidth="150" />
                        <TableColumn fx:id="colPinjamBuku" text="Judul Buku" prefWidth="250" />
                        <TableColumn fx:id="colPinjamTanggal" text="Tgl Pinjam" prefWidth="150" />
                        <TableColumn fx:id="colPinjamStatus" text="Status" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>
        </StackPane>
    </center>
</BorderPane>