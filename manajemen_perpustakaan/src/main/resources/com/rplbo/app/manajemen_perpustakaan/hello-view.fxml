<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rplbo.app.manajemen_perpustakaan.HelloController">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #43b596; -fx-padding: 15;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="PERPUSTAKAAN FURAB&#10;Kota Yogyakarta" textFill="WHITE" />
        </HBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="60" style="-fx-padding: 40;">
            <VBox spacing="10">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="REGISTRASI ANGGOTA ONLINE" />
                <VBox prefWidth="350" style="-fx-background-color: #a3d9c9; -fx-border-color: #2b7a63; -fx-border-width: 2; -fx-padding: 15; -fx-background-radius: 5; -fx-border-radius: 5;" spacing="5">
                    <Label style="-fx-font-weight: bold;" text="PANDUAN" />
                    <Label text="1. Silakan registrasi terlebih dahulu jika belum memiliki akun." wrapText="true" />
                    <Label text="2. Jika sudah mempunyai akun silakan login menggunakan username dan password yang terdaftar." wrapText="true" />
                    <Label text="3. Setelah terdaftar Anda dapat mengakses website ini." wrapText="true" />
                </VBox>
            </VBox>

            <VBox alignment="CENTER" prefWidth="300" spacing="15" style="-fx-background-color: #43b596; -fx-padding: 30; -fx-background-radius: 10;">
                <Label style="-fx-font-weight: bold; -fx-font-size: 18;" text="LOGIN" textFill="WHITE" />
                <TextField fx:id="usernameField" promptText="username" style="-fx-background-radius: 5; -fx-padding: 8;" />
                <PasswordField fx:id="passwordField" promptText="password" style="-fx-background-radius: 5; -fx-padding: 8;" />
                <Button maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #2b7a63; -fx-text-fill: WHITE; -fx-background-radius: 5; -fx-padding: 8;" text="LOGIN" />

                <Hyperlink text="Belum memiliki akun? DAFTAR SEKARANG" textFill="WHITE" style="-fx-font-size: 11; -fx-underline: true;" onAction="#goToRegister"/>

            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="50" style="-fx-background-color: #43b596; -fx-padding: 15;">
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="TENTANG KAMI" textFill="WHITE" />
                <Label text="Perpustakaan Furab Kota Yogyakarta..." textFill="WHITE" />
            </VBox>
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="KONTAK KAMI" textFill="WHITE" />
                <Label text="Jl. Kenari No.56, Muja Muju&#10;Telepon: (0274) 514448" textFill="WHITE" />
            </VBox>
        </HBox>
    </bottom>

</BorderPane>