<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rplbo.app.manajemen_perpustakaan.UserDashboardController"
      prefWidth="900" prefHeight="600" style="-fx-background-color: #f0f4f8;">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <VBox prefWidth="200" style="-fx-background-color: #2d7a5f;">
        <padding><Insets top="24" left="0" right="0" bottom="16"/></padding>

        <Label text="FURAB 💜" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 24 16;"/>

        <Button fx:id="btnMenuKatalog"  text="📚  Katalog Buku"   onAction="#showKatalog"
                maxWidth="Infinity" style="-fx-background-color: #1e5646; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
        <Button fx:id="btnMenuBookmark" text="★  Favorit Saya"    onAction="#showBookmark"
                maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
        <Button fx:id="btnMenuPinjaman" text="📋  Pinjaman Saya"   onAction="#showPinjaman"
                maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Button text="Keluar" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
    </VBox>

    <!-- ═══════════════ KONTEN UTAMA ═══════════════ -->
    <StackPane HBox.hgrow="ALWAYS">

        <!-- ─── HALAMAN KATALOG ─── -->
        <VBox fx:id="pageKatalog" visible="true" style="-fx-background-color: #f0f4f8;">
            <padding><Insets top="24" left="24" right="24" bottom="16"/></padding>

            <Label text="Katalog Buku" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="labelHasilCari" text="Memuat koleksi..." style="-fx-text-fill: #666; -fx-font-size: 13px;"/>

            <HBox spacing="10" style="-fx-padding: 16 0 12 0;" alignment="CENTER_LEFT">
                <!-- Search field -->
                <TextField fx:id="searchField" promptText="🔍  Cari judul atau pengarang..."
                           prefWidth="320" style="-fx-font-size: 14px; -fx-padding: 8 12;"/>

                <!-- Filter genre -->
                <ComboBox fx:id="filterGenre" prefWidth="160" style="-fx-font-size: 13px;"/>

                <Button text="Reset" onAction="#handleResetFilter"
                        style="-fx-background-color: #aaa; -fx-text-fill: white; -fx-padding: 8 16; -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Tombol bookmark -->
                <Button text="★  Toggle Bookmark" onAction="#handleToggleBookmark"
                        style="-fx-background-color: #d4537e; -fx-text-fill: white; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Tabel katalog -->
            <TableView fx:id="katalogTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colBookmark"  text="★"          prefWidth="40"/>
                    <TableColumn fx:id="colJudul"     text="Judul"       prefWidth="260"/>
                    <TableColumn fx:id="colPengarang" text="Pengarang"   prefWidth="160"/>
                    <TableColumn fx:id="colGenre"     text="Genre"       prefWidth="100"/>
                    <TableColumn fx:id="colStatus"    text="Status"      prefWidth="100"/>
                </columns>
                <placeholder><Label text="Tidak ada buku ditemukan"/></placeholder>
            </TableView>

            <Label text="💡 Klik bintang ★ di baris buku untuk toggle bookmark" style="-fx-text-fill: #888; -fx-font-size: 12px; -fx-padding: 8 0 0 0;"/>
        </VBox>

        <!-- ─── HALAMAN BOOKMARK ─── -->
        <VBox fx:id="pageBookmark" visible="false" style="-fx-background-color: #f0f4f8;">
            <padding><Insets top="24" left="24" right="24" bottom="16"/></padding>

            <Label text="★ Favorit Saya" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="labelJumlahBookmark" text="0 buku dalam favorit" style="-fx-text-fill: #666; -fx-font-size: 13px; -fx-padding: 0 0 12 0;"/>

            <TableView fx:id="bookmarkTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colBmJudul"     text="Judul"       prefWidth="280"/>
                    <TableColumn fx:id="colBmPengarang" text="Pengarang"   prefWidth="180"/>
                    <TableColumn fx:id="colBmGenre"     text="Genre"       prefWidth="120"/>
                    <TableColumn fx:id="colBmStatus"    text="Status"      prefWidth="100"/>
                </columns>
                <placeholder><Label text="Belum ada buku favorit. Tambahkan dari Katalog!"/></placeholder>
            </TableView>

            <HBox spacing="10" style="-fx-padding: 12 0 0 0;">
                <Button text="🗑  Hapus dari Favorit" onAction="#handleHapusBookmark"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- ─── HALAMAN PINJAMAN ─── -->
        <VBox fx:id="pagePinjaman" visible="false" style="-fx-background-color: #f0f4f8;">
            <padding><Insets top="24" left="24" right="24" bottom="16"/></padding>

            <Label text="📋 Pinjaman Saya" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Riwayat buku yang sedang atau pernah dipinjam" style="-fx-text-fill: #666; -fx-font-size: 13px; -fx-padding: 0 0 12 0;"/>

            <TableView fx:id="pinjamanTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colPjJudul"     text="Judul"       prefWidth="320"/>
                    <TableColumn fx:id="colPjPengarang" text="Pengarang"   prefWidth="200"/>
                    <TableColumn fx:id="colPjStatus"    text="Status Pinjam" prefWidth="140"/>
                </columns>
                <placeholder><Label text="Kamu belum pernah meminjam buku."/></placeholder>
            </TableView>
        </VBox>

    </StackPane>
</HBox>
