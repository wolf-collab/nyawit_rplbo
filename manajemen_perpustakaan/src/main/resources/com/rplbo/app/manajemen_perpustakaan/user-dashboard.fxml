<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.rplbo.app.manajemen_perpustakaan.UserDashboardController" prefWidth="900" prefHeight="600" style="-fx-background-color: #f0f4f8;">
    <VBox prefWidth="200" style="-fx-background-color: #2d7a5f;">
        <padding><Insets top="24" left="0" right="0" bottom="16"/></padding>
        <Label text="FURAB 💜" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 24 16;"/>
        <Button fx:id="btnMenuKatalog" text="📚  Katalog Buku" onAction="#showKatalog" maxWidth="Infinity" style="-fx-background-color: #1e5646; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
        <Button fx:id="btnMenuBookmark" text="★  Favorit Saya" onAction="#showBookmark" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
        <Button fx:id="btnMenuPinjaman" text="📋  Pinjaman Saya" onAction="#showPinjaman" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
        <Button fx:id="btnMenuLapor" text="⚠️  Pengaduan" onAction="#showLapor" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ffcccc; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand; -fx-font-weight: bold;"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Keluar" onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 16; -fx-cursor: hand;"/>
    </VBox>

    <StackPane HBox.hgrow="ALWAYS">
        <VBox fx:id="pageKatalog" visible="true" style="-fx-background-color: #f0f4f8; -fx-padding: 24;">
            <Label text="Katalog Buku" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="labelHasilCari" text="Memuat koleksi..." style="-fx-text-fill: #666;"/>
            <HBox spacing="10" style="-fx-padding: 16 0 12 0;" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍  Cari judul..." prefWidth="320"/>
                <ComboBox fx:id="filterGenre" prefWidth="160"/>
                <Button text="Reset" onAction="#handleResetFilter" style="-fx-background-color: #aaa; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📖 Pinjam Buku" onAction="#handlePinjamBuku" style="-fx-background-color: #2b7a63; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="★  Toggle Bookmark" onAction="#handleToggleBookmark" style="-fx-background-color: #d4537e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="katalogTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBookmark" text="★" prefWidth="40"/>
                    <TableColumn fx:id="colJudul" text="Judul" prefWidth="260"/>
                    <TableColumn fx:id="colPengarang" text="Pengarang" prefWidth="160"/>
                    <TableColumn fx:id="colGenre" text="Genre" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="pageBookmark" visible="false" style="-fx-background-color: #f0f4f8; -fx-padding: 24;">
            <Label text="★ Favorit Saya" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="labelJumlahBookmark" text="0 buku dalam favorit" style="-fx-text-fill: #666;"/>
            <TableView fx:id="bookmarkTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBmJudul" text="Judul" prefWidth="280"/>
                    <TableColumn fx:id="colBmPengarang" text="Pengarang" prefWidth="180"/>
                    <TableColumn fx:id="colBmGenre" text="Genre" prefWidth="120"/>
                    <TableColumn fx:id="colBmStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
            <Button text="🗑  Hapus dari Favorit" onAction="#handleHapusBookmark" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand; margin-top: 10px;"/>
        </VBox>

        <VBox fx:id="pagePinjaman" visible="false" style="-fx-background-color: #f0f4f8; -fx-padding: 24;">
            <Label text="📋 Pinjaman Saya" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <TableView fx:id="pinjamanTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPjJudul" text="Judul" prefWidth="320"/>
                    <TableColumn fx:id="colPjPengarang" text="Pengarang" prefWidth="200"/>
                    <TableColumn fx:id="colPjStatus" text="Status Pinjam" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="pageLapor" visible="false" style="-fx-background-color: #f0f4f8; -fx-padding: 24;" spacing="15">
            <Label text="⚠️ Layanan Pengaduan" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
            <Label text="Ada buku rusak? Aplikasi error? Laporkan keluhanmu di sini." style="-fx-text-fill: #666;"/>
            <TextArea fx:id="txtKeluhan" promptText="Tulis keluhan atau laporan Anda di sini..." prefHeight="200" wrapText="true" style="-fx-font-size: 14px;"/>
            <Button text="Kirim Laporan" onAction="#kirimLaporan" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
        </VBox>
    </StackPane>
</HBox>